TWILIO_AUTH_TOKEN=your_twilio_auth_token
OPEN_DIGITS=ww9
RECORD_CALLS=true

# Call-handling mode: "auto" (open for everyone) or "passcode"
MODE=auto|passcode
# Passcode mode only: the valid passcode (numDigits is derived from its length)
PASSCODE=
PASSCODE_TIMEOUT=10

# Logs the raw DTMF digits Twilio decoded, to diagnose a panel that garbles or
# drops tones. Writes the passcode to the logs in plaintext: turn on for a test
# window only, then turn off and rotate PASSCODE.
DEBUG_DTMF=false
