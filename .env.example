TWILIO_AUTH_TOKEN=your_twilio_auth_token
OPEN_DIGITS=ww9
RECORD_CALLS=true

# Call-handling mode: "auto" (open for everyone), "passcode", or "voice-agent"
MODE=auto|passcode|voice-agent

# --- passcode mode -----------------------------------------------------------
# The valid passcode (numDigits is derived from its length). Required in
# passcode mode; ignored in the others.
PASSCODE=
PASSCODE_TIMEOUT=10

# Logs the raw DTMF digits Twilio decoded, to diagnose a panel that garbles or
# drops tones. Writes the passcode to the logs in plaintext: turn on for a test
# window only, then turn off and rotate PASSCODE.
DEBUG_DTMF=false

# --- voice-agent mode --------------------------------------------------------
# An LLM talks to the visitor and decides whether to open. Requires a one-time
# opt-in in the Twilio Console (see README) before ConversationRelay will work.
# Required in voice-agent mode.
ANTHROPIC_API_KEY=

# Cheapest and fastest tier; latency is what matters on a phone call.
AGENT_MODEL=claude-haiku-4-5

# Freeform facts about you, injected into the system prompt. This is what lets
# the agent tell a real visitor from a plausible-sounding one, so be specific.
# e.g. "Daniel lives in 4B. Expecting a plumber Tue afternoon. Amazon leaves
# packages in the lobby — they never need to be let in."
AGENT_CONTEXT=

# Spoken before the model is consulted, so the visitor hears something at once.
AGENT_GREETING=Hello, who's there?

# Visitor turns before we give up and deny. Stops a caller talking their way in.
AGENT_MAX_TURNS=6

# Leave unset for Twilio's default voice. To use ElevenLabs, set both.
AGENT_TTS_PROVIDER=
AGENT_VOICE=

# Guards the /relay WebSocket, which Twilio does not sign. Auto-generated per
# process when unset — set it explicitly if you run more than one instance.
RELAY_SECRET=
